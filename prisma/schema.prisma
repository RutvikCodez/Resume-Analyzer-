generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String
  name      String?
  image     String?
  createdAt DateTime @default(now())

  resumes Resume[]

  interviews Interview[]
}

model Resume {
  id             String   @id @default(uuid())
  userId         String
  fileUrl        String
  fileName       String

  overallScore   Int
  atsScore       Int
  toneScore      Int
  contentScore   Int
  structureScore Int
  skillsScore    Int

  rawAIResponse  Json
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  resumeTips        ResumeTip[]
  resumeExperiences ResumeExperience[]
  resumeEducations  ResumeEducation[]

  resumeSkills ResumeSkill[]
}

model ResumeTip {
  id       String   @id @default(uuid())
  resumeId String
  section  ResumeSection
  type     TipType
  tip      String

  resume Resume @relation(fields: [resumeId], references: [id])
}

enum ResumeSection {
  ATS
  TONE
  CONTENT
  STRUCTURE
  SKILLS
}

enum TipType {
  good
  improve
}

model ResumeExperience {
  id          String @id @default(uuid())
  resumeId    String
  jobTitle    String
  company     String
  startDate   String
  endDate     String
  description String

  resume Resume @relation(fields: [resumeId], references: [id])
}

model ResumeEducation {
  id             String @id @default(uuid())
  resumeId       String
  schoolName     String
  educationLevel String
  startDate      String?
  endDate        String?
  cgpaOrMark     String?

  resume Resume @relation(fields: [resumeId], references: [id])
}

model ResumeSkill {
  id       String @id @default(uuid())
  resumeId String
  name     String
  score    Int    // 0–100

  resume Resume @relation(fields: [resumeId], references: [id])
}

model Interview {
  id             String   @id @default(uuid())
  userId         String

  jobTitle       String
  company        String
  location       String?
  interviewLevel String  // easy, medium, hard

  jobDescription String

  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  screeningQuestions InterviewScreeningQuestion[]
  technicalQuestions InterviewTechnicalQuestion[]

  screeningFeedback InterviewScreeningFeedback?
  technicalFeedback InterviewTechnicalFeedback?

  interviewAnswers InterviewAnswer[]
}

model InterviewScreeningQuestion {
  id          String @id @default(uuid())
  interviewId String
  question    String

  interview Interview @relation(fields: [interviewId], references: [id])
}

model InterviewTechnicalQuestion {
  id          String @id @default(uuid())
  interviewId String
  question    String

  interview Interview @relation(fields: [interviewId], references: [id])
}

model InterviewScreeningFeedback {
  id          String @id @default(uuid())
  interviewId String @unique

  score       Int
  feedback    String
  strengths   String[]
  improvements String[]

  createdAt   DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id])
}

model InterviewTechnicalFeedback {
  id          String @id @default(uuid())
  interviewId String @unique

  score       Int
  feedback    String
  strengths   String[]
  improvements String[]

  createdAt   DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id])
}

model InterviewAnswer {
  id          String @id @default(uuid())
  interviewId String
  questionId  String
  answer      String

  type        String // "screening" | "technical"

  interview Interview @relation(fields: [interviewId], references: [id])
}